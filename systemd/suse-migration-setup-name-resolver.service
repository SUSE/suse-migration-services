[Unit]
Description=Setup Migration Name Resolver
After=suse-migration-mount-system.service suse-migration-post-mount-system.service network-online.target
Requires=suse-migration-mount-system.service suse-migration-post-mount-system.service network-online.target
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/suse-migration-setup-name-resolver
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
